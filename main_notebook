p=normal, bottom=inverted\", fontsize=12)\n    plt.tight_layout()\n    plt.savefig(OUT/f\"frame{fi}_76x76.png\", dpi=150)\n    plt.close()\n    log(f\"  Saved frame{fi}_76x76.png\")\n\n# ── Plot 2: Best-guess main image (all 3 frames side by side) ─\nlog(\"\\n[2] All frames at offset=0, both polarities...\")\nfig, axes = plt.subplots(2, max(3, len(frames_raw)), figsize=(6*len(frames_raw), 14))\n\nfor fi, fp in enumerate(frames_raw):\n    img = fp[:W*H].reshape(H, W)\n    axes[0, fi].imshow(img,     cmap='gray', aspect='equal', interpolation='nearest')\n    axes[0, fi].set_title(f\"Frame {fi}  76×76  (normal)\", fontsize=11)\n    axes[0, fi].axis('off')\n    axes[1, fi].imshow(1-img,   cmap='gray', aspect='equal', interpolation='nearest')\n    axes[1, fi].set_title(f\"Frame {fi}  76×76  (inverted)\", fontsize=11)\n    axes[1, fi].axis('off')\n\n# If fewer than 4 frames, mark missing\nfor fi in range(len(frames_raw), axes.shape[1]):\n    axes[0, fi].text(0.5, 0.5, \"NOT\\nFOUND\", ha='center', va='center',\n                     transform=axes[0, fi].transAxes, fontsize=14)\n    axes[0, fi].axis('off')\n    axes[1, fi].axis('off')\n\nplt.suptitle(\"76×76 constellation images — each frame = one image\", fontsize=13)\nplt.tight_layout()\nplt.savefig(OUT/\"all_frames_76x76.png\", dpi=200)\nplt.close()\nlog(\"  Saved all_frames_76x76.png\")\n\n# ── Plot 3: Search for 4th frame using relaxed sync threshold ─\nlog(\"\\n[3] Searching for 4th sync candidate (threshold ≥24)...\")\nsync_bits = np.unpackbits(\n    np.array([0x1ACFFC1D], dtype=\">u4\").view(np.uint8))\nNFFT = 32\n\nscores = np.zeros(len(bits), dtype=np.int32)\nfor i in range(len(bits) - NFFT):\n    scores[i] = int(np.sum(bits[i:i+NFFT] == sync_bits))\n\n# find all peaks ≥24 with minimum spacing of 1000 bits\ncandidates = []\nmin_spacing = 1000\nlast = -min_spacing\nfor i in np.where(scores >= 24)[0]:\n    if i - last >= min_spacing:\n        candidates.append((int(i), int(scores[i])))\n        last = i\n\nlog(f\" 